---
import Base from '../layouts/Base.astro';
---

<Base title="404 — vibereport" description="Page not found.">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <h1 class="text-6xl sm:text-8xl font-bold text-tokyo-cyan animate-fade-in-up">404</h1>
    <p class="mt-4 text-lg sm:text-xl text-tokyo-text animate-fade-in-up" style="animation-delay: 0.1s;">
      Page not found.
    </p>
    <p class="mt-2 text-sm text-tokyo-dimmed animate-fade-in-up" style="animation-delay: 0.2s;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-tokyo-surface border border-tokyo-border/50 text-tokyo-cyan hover:bg-tokyo-surface/80 hover:border-tokyo-cyan/30 transition-all animate-fade-in-up"
      style="animation-delay: 0.3s;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      back to home
    </a>
  </section>
</Base>
